{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.SignalR": "Warning",
        "Microsoft.AspNetCore.Diagnostics.ExceptionHandlerMiddleware": "Fatal"
      }
    }
  },
  "ConnectionStrings": {
    "Logs": "Data Source=logs.db"
  },
  "LogIngest": {
    "PersistMinimumLevel": "Warning",
    "AlwaysPersistCategories": [ "Critical", "DataAccess", "HubConnection" ],
    "QueueCapacity": 10000,
    "PersistBatchSize": 100
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
